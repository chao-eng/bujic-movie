# Bujic Movie 配置文件示例

server:
  port: 8080
  mode: debug          # debug 或 release
  secret_key: "change_me_to_something_secure" # 用于 JWT 签名

database:
  db_path: "data/bujic-movie.db" # SQLite 数据库路径

tmdb:
  api_key: ""          # TMDB API Key (必须配置才能使用刮削功能)
  base_url: "https://api.themoviedb.org/3"
  language: "zh-CN"    # 默认语言 zh-CN 或 en-US

media:
  movie_path: "/media/Movies"      # 整理后的电影库目标路径
  tv_path: "/media/TV"            # 整理后的电视剧库目标路径
  download_path: "/downloads"      # 下载器下载完成 of 源路径

transfer:
  mode: "link"                     # 默认转移模式: copy (复制), move (移动), link (硬链接), softlink (软链接)
  overwrite_mode: "size"           # 默认覆盖模式: always, never, size (大覆盖小), latest (保留最新)
  auto_scrape: true                # 整理完成后是否自动触发刮削
  ignore_extensions:               # 整理时忽略的文件后缀
    - ".txt"
    - ".url"
    - ".nfo"
    - ".jpg"
    - ".png"
  min_file_size_mb: 50             # 过滤小于该大小的非视频文件 (例如广告片、样片)
